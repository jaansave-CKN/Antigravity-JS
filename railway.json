{
  "services": [
    {
      "name": "backend",
      "source": {
        "path": "/backend"
      },
      "dockerfile": {
        "path": "/Dockerfile.backend"
      },
      "env": {
        "JWT_SECRET": "${JWT_SECRET}",
        "ENVIRONMENT": "production"
      }
    },
    {
      "name": "frontend",
      "source": {
        "path": "/"
      },
      "dockerfile": {
        "path": "/Dockerfile.frontend"
      },
      "env": {
        "VITE_API_URL": "${RAILWAY_STATIC_URL}/api"
      }
    }
  ]
}