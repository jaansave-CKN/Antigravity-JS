# RadarFondos 360 - Producción
# ⚠️  Este archivo contiene placeholders. Configure JWT_SECRET, DATABASE_URL
#     y otras variables sensibles en el dashboard de Render, NO en este archivo.
APP_NAME="Radar Fondos 360"
ENVIRONMENT=production

# JWT Secret (generar con: openssl rand -hex 32 y poner en Render)
JWT_SECRET=REPLACE_WITH_SECURE_SECRET_IN_RENDER_DASHBOARD

# API Keys
OPENROUTER_API_KEY=
SERPER_API_KEY=

# Configuración
ALLOWED_ORIGINS=*
WS_PORT=8000
RADAR_INTERVAL_HOURS=6